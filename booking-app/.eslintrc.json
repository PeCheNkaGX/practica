{
  "extends": [
    "@nuxtjs/eslint-config-typescript",
    "plugin:prettier/recommended"
  ],
  "rules": {
    "vue/multi-word-component-names": "off",
    "prettier/prettier": ["error", {
      "semi": false,
      "singleQuote": true,
      "tabWidth": 2,
      "trailingComma": "es5"
    }]
  }
}